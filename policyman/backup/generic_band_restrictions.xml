<?xml version="1.0" encoding="UTF-8"?>

<!-- Post Policy for US location
$Header: //components/rel/mmcp.mpss/10.0/policyman/configurations/Carrier/GenericCountry/generic_band_restrictions.xml#4 $
-->
<policy name        = "Generic Band Restrictions"
        changelist  = "$Change: 19373687 $"
        policy_ver  = "1101.2.19"
>

  <initial>

    <mcc_list name="post:us_mccs" ns="global"> 310 311 312 313 314 315 316 330 302 </mcc_list>

    <mcc_list name="post:singapore_mccs" ns="global"> 525 </mcc_list>

    <mcc_list name="post:australia_mccs" ns="global"> 505 </mcc_list>

    <!--YangXiaolin@NETWORK.REG,2076048, 2021/11/8, disable band according to indonesia req -->
    <mcc_list name="post:indonesia_mccs" ns="global"> 510 </mcc_list>

    <mcc_list name="post:tw_mccs" ns="global"> 466 </mcc_list>

    <!-- WanCheng.Yang@NETWORK.REG, 2025/12/04, diable WCDMA & GSM in home for JP -->
    <mcc_list name="post:jp_mccs" ns="global"> 440 441 </mcc_list>

    <!-- #ifndef VENDOR_EDIT -->
    <!--Baozhu@NETWORK.REG,473278, 2020/10/12, disable B40 B42 ,disable N77,N78 according to FCC -->
    <!--
    <rf_band_list ns="global" name="post:fcc_compliant_bands">
      <gw_bands  base="current" />
      <lte_bands base="current">
        <exclude> 6 37 </exclude>
      </lte_bands>
      <tds_bands base="none" />
      <nr5g_sa_bands base="current" />
      <nr5g_nsa_bands base="current" />
    </rf_band_list>
    -->
    <rf_band_list ns="global" name="post:fcc_compliant_bands">
      <gw_bands  base="current" />
      <lte_bands base="current">
        <exclude> 39 41 </exclude>
      </lte_bands>
      <nr5g_sa_bands base="current">
      <!--liuhaoming@NETWORK.REG.8692416, 2025/02/12, enable N77 and N78 start-->
        <exclude> 39 </exclude>
      </nr5g_sa_bands>
      <nr5g_nsa_bands base="current">
        <exclude> 39 </exclude>
      <!--liuhaoming@NETWORK.REG.8692416, 2025/02/12, enable N77 and N78 end-->
      </nr5g_nsa_bands>
    </rf_band_list>
    <!--#endif VENDOR_EDIT -->
    <!--#ifdef OPLUS_BUG_DEBUG -->
    <!--YangXiaolin@NETWORK.REG,2076048, 2021/11/8, add for disable band according to indonesia req -->
    <rf_band_list ns="global" name="post:disable_indonesia_bands">
      <gw_bands  base="none">
        <include> 7 8 9 20 22 49 </include>
      </gw_bands>
      <lte_bands base="none">
        <include> 0 2 4 7 39 </include>
      </lte_bands>
      <nr5g_sa_bands base="none">
        <include> 0 2 4 7 39 </include>
      </nr5g_sa_bands>
      <nr5g_nsa_bands base="none">
        <include> 0 2 4 7 39 </include>
      </nr5g_nsa_bands>
    </rf_band_list>
    <!--#endif OPLUS_BUG_DEBUG -->
    <rf_band_list ns="global" name="post:disable_GSM_bands">
      <gw_bands  base="current">
        <exclude> 7 8 9 16 17 18 19 20 21 </exclude>
      </gw_bands>
      <lte_bands base="current" />
      <nr5g_sa_bands base="current" />
      <nr5g_nsa_bands base="current" />
    </rf_band_list>

    <define_fullrat_config is_post="true">
      <rf_bands list="global:default_bands" />
      <limited_rats_bands list="global:default_bands" />
    </define_fullrat_config>

  </initial>

  <if>
    <any_of>
      <not> <phone_operating_mode> ONLINE </phone_operating_mode> </not>
      <not> <have_location /> </not>
    </any_of>
    <then> 
      <stop />
    </then>
  </if>

  <svc_mode> FULL </svc_mode>
  
  <select>
  <!-- WanCheng.Yang@NETWORK.REG, 2025/12/04, diable WCDMA & GSM in home for JP -->
    <case>
      <imsi_mcc_in list="post:jp_mccs" />
      <actions>
        <if>
            <location_mcc_in list="post:jp_mccs" />
            <then>
              <rat_capability base="current" >
                <exclude> G W </exclude>
              </rat_capability>
            </then>
        <else>
            <rat_capability base="hardware" />
        </else>
        </if>
      </actions>
    </case>
  <!-- Baozhu.Yu@NETWORK.REG,5427190, 2023/07/10, diable GSM in home for TW and enable GSM Roaming for TW -->
    <case>
      <imsi_mcc_in list="post:tw_mccs" />
      <actions>
        <if>
            <location_mcc_in list="post:tw_mccs" />
            <then>
              <rat_capability base="current" >
                <exclude> G </exclude>
              </rat_capability>
            </then>
        <else>
            <rat_capability base="hardware" />
        </else>
        </if>
      </actions>
    </case>
  <!-- Baozhu.Yu@NETWORK.REG,5427190, 2023/07/10, diable GSM in home for TW and enable GSM Roaming for TW -->
    <case>
      <location_mcc_in list="post:us_mccs" />
      <then>
        <rf_bands list="post:fcc_compliant_bands" />
        <limited_rats_bands list="global:default_bands" />
      </then>
    </case>
    <!--#ifdef OPLUS_BUG_DEBUG -->
    <!--YangXiaolin@NETWORK.REG,2076048, 2021/11/8, add for disable band according to indonesia req -->
    <case>
      <location_mcc_in list="post:indonesia_mccs" />
      <then>
        <rf_bands list="post:disable_indonesia_bands" />
        <limited_rats_bands list="global:disable_indonesia_bands" />
      </then>
    </case>
    <!--#endif OPLUS_BUG_DEBUG -->
    <case>
      <any_of>
        <location_mcc_in list="post:singapore_mccs" />
        <!--#ifdef OPLUS_BUG_COMPATIBILITY -->
        <!-- Xiaolong.Su@NETWORK.REG,3060997, 2022/02/14, enable GSM for AU -->
        <!-- <location_mcc_in list="post:australia_mccs" /> -->
        <!-- endif OPLUS_BUG_COMPATIBILITY -->
      </any_of>
      <then>
        <rf_bands list="post:disable_GSM_bands" />
        <limited_rats_bands list="post:disable_GSM_bands" />
      </then>
    </case>

    <case>
      <true />
      <then>
        <rf_bands list="global:default_bands" />
        <limited_rats_bands list="global:default_bands" />
      </then>
    </case>
  </select>

</policy>